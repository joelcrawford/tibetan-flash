{
    "output": {
        "filePath": "shared/data/pack/repopack-tibetan-flash.txt",
        "style": "plain",
        "parsableStyle": false,
        "fileSummary": true,
        "directoryStructure": true,
        "removeComments": false,
        "removeEmptyLines": false,
        "compress": false,
        "topFilesLength": 5,
        "showLineNumbers": false,
        "copyToClipboard": false
    },
    "include": [],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "*.db",
            "**/output/**",
            "**/python/**",
            "**/_auth/**",
            "**/data/**",
            "**/logs/**",
            "**/docs/**",
            "**/.venv/**",
            "**/venv/**",
            "**/.vscode/**",
            "**/src/_archive/**",
            "**_archives/**"
        ]
    },
    "security": {
        "enableSecurityCheck": true
    },
    "tokenCount": {
        "encoding": "o200k_base"
    }
}